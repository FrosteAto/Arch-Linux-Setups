{
  "archinstall-language": "English",

  "bootloader_config": {
    "bootloader": "Grub",
    "removable": true,
    "uki": false
  },

  "disk_config": {
    "config_type": "default_layout",
    "device_modifications": [
      {
        "device": "AUTO",
        "wipe": true,
        "partitions": "AUTO"
      }
    ]
  },

  "hostname": "FrosteArch PC",

  "kernels": ["linux"],

  "locale_config": {
    "kb_layout": "uk",
    "sys_enc": "UTF-8",
    "sys_lang": "en_GB.UTF-8"
  },

  "mirror_config": {
    "mirror_regions": {}
  },

  "network_config": { "type": "nm" },

  "ntp": true,

  "profile_config": {
    "profile": {
      "main": "Minimal",
      "details": [],
      "custom_settings": {}
    },
    "gfx_driver": null,
    "greeter": null
  },

  "swap": {
    "enabled": true,
    "algorithm": "zstd"
  },

  "timezone": "Europe/London",

  "custom_commands": [
  "git clone https://github.com/FrosteAto/Arch-Linux-Setups.git /root/installer",
  "bash /root/installer/install.sh"
  ]
}