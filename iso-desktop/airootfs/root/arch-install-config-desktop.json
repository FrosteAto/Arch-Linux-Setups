{
  "archinstall-language": "English",

  "bootloader_config": {
    "bootloader": "Grub",
    "removable": true,
    "uki": false
  },

  "hostname": "FrosteArch PC",

  "kernels": ["linux"],

  "locale_config": {
    "kb_layout": "uk",
    "sys_enc": "UTF-8",
    "sys_lang": "en_GB.UTF-8"
  },

  "mirror_config": {
    "mirror_regions": {}
  },

  "network_config": { "type": "nm" },

  "ntp": true,

  "profile_config": {
    "profile": {
      "main": "Minimal",
      "details": [],
      "custom_settings": {}
    },
    "gfx_driver": null,
    "greeter": null
  },

  "swap": {
    "enabled": true,
    "algorithm": "zstd"
  },

  "timezone": "Europe/London",

  "packages": [
    "git"
  ],

"custom_commands": [
  "git clone https://github.com/FrosteAto/Arch-Linux-Setups.git /root/installer",
  "bash -lc 'set -euo pipefail; mkdir -p /var/log/arch-linux-setups; LOG=/var/log/arch-linux-setups/install-$(date +%F_%H-%M-%S).log; echo \"==> Running installer (MODE=desktop)\"; echo \"==> Logging to $LOG\"; stdbuf -oL -eL MODE=desktop bash /root/installer/install.sh 2>&1 | tee -a \"$LOG\"'"
]
}