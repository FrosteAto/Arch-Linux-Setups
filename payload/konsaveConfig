---
# This is the configuration file for konsave.
# This file is pre-configured for KDE Plasma users.
# This will backup all the important files for your Plasma customizations.
# Please make sure it follows the correct format for proper working of Konsave.
# The format should be:
# ---
# save:
#     name:
#         location: "path/to/parent/directory"
#         entries: 
#         # these are files which will be backed up. 
#         # They should be present in the specified location.
#             - file1
#             - file2
# export:
#     # This includes files which will be exported with your profile.
#     # They will not be saved but only be exported and imported.
#     # These may include files like complete icon packs and themes..
#     name:
#         location: "path/to/parent/directory"
#         entries: 
#             - file1
#             - file2
# ...
# You can use these placeholders in the "location" of each item:
# $HOME: the home directory
# $CONFIG_DIR: refers to "$HOME/.config/"
# $SHARE_DIR: refers to "$HOME/.local/share"
# $BIN_DIR: refers to "$HOME/.local/bin"
# ${ENDS_WITH="text"}: for folders with different names on different computers whose names end with the same thing.
# The best example for this is the "*.default-release" folder of firefox.
# ${BEGINS_WITH="text"}: for folders with different names on different computers whose names start with the same thing.

# NOTE: Color scheme activation is handled by frostearch-theme-switcher after
# konsave is applied. Konsave's role here is to export the scheme assets
# (for example color-schemes/) and baseline KDE config files.

save:
    configs:
        location: "$CONFIG_DIR"
        entries:
            # GTK theming
            - gtk-2.0
            - gtk-3.0
            - gtk-4.0
            - gtkrc
            - gtkrc-2.0
            - Kvantum
            # KDE window manager & compositor
            - kwinrc
            - kwinrulesrc
            # KDE Plasma shell & panel layout
            - plasma-org.kde.plasma.desktop-appletsrc
            - plasmarc
            - plasmashellrc
            # Appearance: colors, icons, cursor, fonts, splash
            # kdeglobals carries: ColorScheme, Icons/Theme, CursorTheme,
            # CursorSize, accent color, and system fonts.
            # Make sure ColorScheme= is present before exporting (see note above).
            - kdeglobals
            # kcminputrc carries: cursor theme + size ([Mouse] section),
            # and all libinput device-level pointer settings.
            - kcminputrc
            - breezerc
            - oxygenrc
            - lightlyrc
            - ksplashrc
            - kscreenlockerrc
            # fontconfig stores per-user font rendering preferences (hinting, subpixel, etc.)
            - fontconfig
            # KDE app configs
            - dolphinrc
            - katerc
            - konsolerc
            - kate
            - krunnerrc
            - ksmserverrc
            - kglobalshortcutsrc
            - klipperrc
            - khotkeysrc
            - fastfetch
            # Legacy / optional panel docks
            - latte
            - lattedockrc

    app_layouts:
        location: "$HOME/.local/share/kxmlgui5"
        entries:
            - dolphin
            - konsole

    # Here are a few examples of how you can add more stuff to back up.
    # Uncomment these lines if you want.
    # firefox:
    #     location: "$HOME/.mozilla/firefox/${ENDS_WITH='.default-release'}"
    #     entries:
    #         - chrome # for firefox customizations

    # code oss:
    #     location: "$CONFIG_DIR/Code - OSS/User/"
    #     entries:
    #         - settings.json


# The following files will only be used for exporting and importing.
export:
    share_folder:
        location: "$SHARE_DIR"
        entries:
            # Plasma plasmoids, look-and-feel packages, layout templates
            - plasma
            # KWin scripts and effect configs
            - kwin
            # Konsole color schemes and profiles
            - konsole
            # User-installed fonts
            - fonts
            # KDE color scheme .colors files (e.g. CatppuccinMocha.colors)
            - color-schemes
            # Window decoration themes (Aurorae)
            - aurorae
            # Icon packs (YAMIS, etc.) and cursor themes installed to share/icons
            - icons
            # GTK themes installed to ~/.local/share/themes
            - themes

    home_folder:
        location: "$HOME/"
        entries:
            # User fonts in legacy location
            - .fonts
            # GTK themes in legacy location
            - .themes
            # Cursor themes installed to ~/.icons (e.g. Ninomae-Ina'nis)
            - .icons
    
        
    # You can add more files to export like this
    # name:
    #     location: "path/to/parent/directory"
    #     entries:
    #         - file1
    #         - file2
    #         - folder1
    #         - folder2
...
